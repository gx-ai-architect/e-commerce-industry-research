---
const { title = 'E-Commerce Industry Research' } = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <style>
    :root {
      --text: #1a1a1a;
      --bg: #fafaf9;
      --accent: #2563eb;
      --border: #e5e5e5;
      --muted: #6b7280;
      --max-width: 720px;
    }

    * { margin: 0; padding: 0; box-sizing: border-box; }

    body {
      font-family: 'Georgia', 'Times New Roman', serif;
      color: var(--text);
      background: var(--bg);
      line-height: 1.7;
      font-size: 18px;
    }

    main {
      max-width: var(--max-width);
      margin: 0 auto;
      padding: 3rem 1.5rem 6rem;
    }

    h1 {
      font-size: 2.2rem;
      line-height: 1.2;
      margin-bottom: 0.5rem;
      font-weight: 700;
    }

    h2 {
      font-size: 1.5rem;
      margin-top: 3rem;
      margin-bottom: 1rem;
      padding-bottom: 0.5rem;
      border-bottom: 1px solid var(--border);
      font-weight: 600;
    }

    h3 {
      font-size: 1.2rem;
      margin-top: 2rem;
      margin-bottom: 0.75rem;
      font-weight: 600;
    }

    p {
      margin-bottom: 1.2rem;
    }

    .subtitle {
      color: var(--muted);
      font-size: 0.95rem;
      font-style: italic;
      margin-bottom: 2rem;
    }

    a {
      color: var(--accent);
      text-decoration: none;
    }

    a:hover {
      text-decoration: underline;
    }

    table {
      width: 100%;
      border-collapse: collapse;
      margin: 1.5rem 0;
      font-size: 0.9rem;
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    }

    th, td {
      padding: 0.6rem 0.8rem;
      text-align: left;
      border-bottom: 1px solid var(--border);
    }

    th {
      font-weight: 600;
      background: #f5f5f4;
      font-size: 0.85rem;
      text-transform: uppercase;
      letter-spacing: 0.03em;
    }

    blockquote {
      border-left: 3px solid var(--accent);
      padding-left: 1rem;
      margin: 1.5rem 0;
      color: var(--muted);
      font-style: italic;
    }

    code {
      font-family: 'SF Mono', 'Fira Code', monospace;
      font-size: 0.85em;
      background: #f5f5f4;
      padding: 0.15em 0.4em;
      border-radius: 3px;
    }

    pre {
      background: #1e1e1e;
      color: #d4d4d4;
      padding: 1.2rem;
      border-radius: 6px;
      overflow-x: auto;
      margin: 1.5rem 0;
      font-size: 0.85rem;
      line-height: 1.5;
    }

    pre code {
      background: none;
      padding: 0;
      color: inherit;
    }

    sup a {
      color: var(--accent);
      font-size: 0.75em;
      text-decoration: none;
      font-weight: 600;
    }

    sup a:hover {
      text-decoration: underline;
    }

    .evidence-section {
      margin-top: 4rem;
      padding-top: 2rem;
      border-top: 2px solid var(--border);
    }

    .evidence-entry {
      margin-bottom: 1.2rem;
      font-size: 0.9rem;
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
      line-height: 1.5;
    }

    .evidence-id {
      font-weight: 700;
      color: var(--accent);
    }

    .evidence-quote {
      color: var(--muted);
      font-style: italic;
    }

    ul, ol {
      margin-bottom: 1.2rem;
      padding-left: 1.5rem;
    }

    li {
      margin-bottom: 0.4rem;
    }

    strong {
      font-weight: 700;
    }

    hr {
      border: none;
      border-top: 1px solid var(--border);
      margin: 2rem 0;
    }

    @media (max-width: 600px) {
      body { font-size: 16px; }
      h1 { font-size: 1.8rem; }
      main { padding: 2rem 1rem 4rem; }
      table { font-size: 0.8rem; }
      th, td { padding: 0.4rem; }
    }
  </style>
</head>
<body>
  <main>
    <slot />
  </main>
</body>
</html>
