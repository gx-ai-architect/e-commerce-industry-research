---
import Base from '../../../layouts/Base.astro';
import LineChart from '../../../components/LineChart.astro';
import BarChart from '../../../components/BarChart.astro';
import fs from 'node:fs';
import path from 'node:path';
import { marked } from 'marked';

const reportPath = path.resolve('..', 'reports', 'pdd-holdings', 'report-v3.md');
const evidencePath = path.resolve('..', 'reports', 'pdd-holdings', 'evidence-v3.json');
const chartsPath = path.resolve('..', 'reports', 'pdd-holdings', 'charts-v3.json');

let reportMd = '';
let evidence: Array<{id: string, url: string, quote: string, date: string, provenance?: string}> = [];
let charts: Record<string, any> = {};

try {
  reportMd = fs.readFileSync(reportPath, 'utf-8');
} catch {
  reportMd = '# Report Not Yet Generated\n\nRun the deep-research SKILL to generate the PDD Holdings V3 report.';
}

try {
  const raw = fs.readFileSync(evidencePath, 'utf-8');
  evidence = JSON.parse(raw);
} catch {
  evidence = [];
}

try {
  const raw = fs.readFileSync(chartsPath, 'utf-8');
  charts = JSON.parse(raw);
} catch {
  charts = {};
}

// Remove chart placeholder comments from markdown before parsing
// We'll render charts as Astro components instead
const chartIds = Object.keys(charts);
let cleanMd = reportMd;
for (const id of chartIds) {
  cleanMd = cleanMd.replace(`<!-- CHART:${id} -->`, `<div id="chart-placeholder-${id}"></div>`);
}

let reportHtml = await marked.parse(cleanMd);
reportHtml = reportHtml.replace(/\[E(\d+)\]/g, '<sup><a href="#evidence-$1" id="ref-$1" class="evidence-ref">[$1]</a></sup>');

// Split HTML at chart placeholders so we can inject Astro components
const parts = reportHtml.split(/<div id="chart-placeholder-(\w+)"><\/div>/);
// parts alternates: [htmlBefore, chartId, htmlAfter, chartId, htmlAfter, ...]
---

<Base title="PDD Holdings V3.1: The Metamorphosis — E-commerce Analysis">
  <nav class="report-nav">
    <a href={`${import.meta.env.BASE_URL}`}>&larr; All Reports</a>
    <span class="nav-sep">|</span>
    <a href={`${import.meta.env.BASE_URL}reports/pdd-holdings-v2/`}>V2 Report</a>
    <span class="nav-sep">|</span>
    <a href={`${import.meta.env.BASE_URL}reports/pdd-holdings/`}>V1 Report</a>
  </nav>

  <article>
    {parts.map((part, i) => {
      if (i % 2 === 0) {
        // HTML content
        return <Fragment set:html={part} />;
      } else {
        // Chart ID
        const chart = charts[part];
        if (!chart) return null;
        if (chart.type === 'bar') {
          return <BarChart title={chart.title} bars={chart.bars} yLabel={chart.yLabel} />;
        } else if (chart.type === 'line') {
          return <LineChart title={chart.title} datasets={chart.datasets} xLabels={chart.xLabels} yLabel={chart.yLabel} />;
        }
        return null;
      }
    })}
  </article>

  {evidence.length > 0 && (
    <section class="evidence-section">
      <h2>Sources & Evidence Chain</h2>
      <p class="evidence-intro">Every claim in this report is backed by a verifiable source. Click any footnote number to jump here; click the URL to verify.</p>
      <div class="evidence-legend">
        <span class="legend-item"><span class="legend-swatch legend-green"></span> Machine-collected from API with verified provenance</span>
        <span class="legend-item"><span class="legend-swatch legend-blue"></span> Manually collected by researcher</span>
      </div>
      {evidence.map((e) => {
        const isAuto = e.provenance && e.provenance.startsWith('auto:');
        return (
          <div class={`evidence-entry ${isAuto ? 'evidence-auto' : ''}`} id={`evidence-${e.id.replace('E', '')}`}>
            <span class="evidence-id">[{e.id}]</span>{' '}
            {isAuto && (
              <span class="prov-auto">{e.provenance!.replace('auto:', '')}</span>
            )}
            {!isAuto && e.provenance && (
              <span class="prov-manual">manual</span>
            )}
            <a href={e.url} target="_blank" rel="noopener">{(() => { try { const u = new URL(e.url); return u.hostname + u.pathname.substring(0, 50); } catch { return e.url.substring(0, 60); } })()}</a>
            {e.date && <span class="evidence-date">({e.date})</span>}
            {e.quote && <div class="evidence-quote">"{e.quote}"</div>}
            <a href={`#ref-${e.id.replace('E', '')}`} class="back-ref">&hookleftarrow;</a>
          </div>
        );
      })}
    </section>
  )}
</Base>

<style>
  .report-nav {
    margin-bottom: 2rem;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    font-size: 0.9rem;
  }

  .report-nav a {
    color: #6b7280;
    text-decoration: none;
  }

  .report-nav a:hover {
    color: #2563eb;
  }

  .nav-sep {
    color: #d1d5db;
    margin: 0 0.5rem;
  }

  .evidence-date {
    color: #9ca3af;
    font-size: 0.8rem;
    margin-left: 0.5rem;
  }

  .evidence-intro {
    color: #6b7280;
    font-size: 0.9rem;
    margin-bottom: 0.75rem;
  }

  .evidence-legend {
    display: flex;
    gap: 1.5rem;
    margin-bottom: 1.5rem;
    font-size: 0.8rem;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    color: #6b7280;
  }

  .legend-item {
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }

  .legend-swatch {
    display: inline-block;
    width: 12px;
    height: 12px;
    border-radius: 2px;
  }

  .legend-green {
    background: #059669;
  }

  .legend-blue {
    background: #2563eb;
  }

  .evidence-entry {
    margin-bottom: 1.2rem;
    font-size: 0.9rem;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    line-height: 1.5;
    padding: 0.5rem 0.75rem;
    border-left: 4px solid transparent;
  }

  .evidence-auto {
    border-left: 4px solid #059669;
    background: #f0fdf4;
    border-radius: 0 4px 4px 0;
  }

  .prov-auto,
  .prov-manual {
    display: inline-block;
    font-size: 0.7rem;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    font-weight: 600;
    padding: 0.1rem 0.4rem;
    border-radius: 3px;
    text-transform: uppercase;
    letter-spacing: 0.03em;
    margin-right: 0.3rem;
  }

  .prov-auto {
    background: #d1fae5;
    color: #065f46;
  }

  .prov-manual {
    background: #dbeafe;
    color: #1d4ed8;
  }

  .evidence-id {
    font-weight: 700;
    color: #2563eb;
  }

  .evidence-auto .evidence-id {
    color: #059669;
  }

  .evidence-quote {
    color: #6b7280;
    font-style: italic;
  }

  .back-ref {
    color: #9ca3af;
    font-size: 0.8rem;
    margin-left: 0.3rem;
    text-decoration: none;
  }

  .back-ref:hover {
    color: #2563eb;
  }
</style>
