---
import Base from '../layouts/Base.astro';

const reports = [
  {
    slug: 'pdd-2026-horizon',
    title: 'PDD Holdings: Five Questions for 2026',
    subtitle: 'Earnings-day report (March 25, 2026). FY2025: revenue +10%, op profit -13%, $83.5B liquid assets. Q4 margin inflection (+8.3% YoY). SCOTUS halved tariffs but de minimis dead. OMS growth peaked at +5%. Zero capital return despite 56% cash/mcap. Li Lu bought $482M; Tiger Global sold 100%. 5 thesis-driven questions, 54 evidence packets, 33 curated citations.',
    authors: 'GX Xu & Claude Code',
    date: 'March 25, 2026',
    version: 'Horizon',
    tag: 'E-Commerce · China · 2026 Outlook',
    readTime: '22 min read',
  },
  {
    slug: 'pdd-holdings-v5',
    title: 'PDD Holdings: The Algorithm, The Fortress, and The Free Option',
    subtitle: 'Buffett/Li Lu quality gate applied. How PDD actually makes money: feed-first algorithm (70-80% algorithmic traffic), cross-platform price surveillance, 500+ engineers in Darwinian competition. Merchant P&L across 4 platforms. Moat is cost structure, NOT switching costs. ROIC 16.7-78%. Owner earnings $14.2B at 5.0x EV/OE. 78 curated citations, 73 evidence packets from 8 agents.',
    authors: 'GX Xu & Claude Code',
    date: 'March 24, 2026',
    version: 'V5',
    tag: 'E-Commerce · China · Deep Research',
    readTime: '28 min read',
  },
  {
    slug: 'novo-nordisk',
    title: 'Novo Nordisk: Is the GLP-1 King Dead or Just Repriced?',
    subtitle: 'NVO at $36.84 — 10.1x PE for a DKK 102B earner with 33% margins and 61% ROE. Down 75% from ATH. Oral Wegovy is the fastest drug launch in history (400K patients in 10 weeks). But Lilly won the head-to-head trial, CagriSema failed, and the CEO was fired. 62 evidence citations. 5 charts. 5 predictions.',
    authors: 'GX Xu & Claude Code',
    date: 'March 23, 2026',
    version: 'V1',
    tag: 'Biotech · Denmark · Deep Research',
    readTime: '30 min read',
  },
  {
    slug: 'china-ecommerce-industry',
    title: 'Chinese E-Commerce: PDD Earnings Preview — The Balance Sheet Fortress',
    subtitle: 'PDD reports March 25. $69.5B total liquid assets, $68B net cash — 4.1x more than Alibaba. 49.8% of stock price is cash. The only profitable Chinese e-commerce platform. Every number from Yahoo Finance API and Alpaca Markets API.',
    authors: 'GX Xu & Claude Code',
    date: 'March 23, 2026',
    version: 'V4',
    tag: 'E-Commerce · China · Earnings Preview',
    readTime: '25 min read',
  },
  {
    slug: 'amazon',
    title: 'Amazon: The $200 Billion Bet',
    subtitle: '8 research agents dissected AWS, e-commerce, advertising, and international segments. Head-to-head comparison with BABA, JD, PDD, Douyin. 40 evidence citations. 3 mosaic insights, 5 predictions. Is the largest capex bet in corporate history justified?',
    authors: 'GX Xu & Claude Code',
    date: 'March 22, 2026',
    version: 'V1',
    tag: 'E-Commerce · US · Deep Research',
    readTime: '25 min read',
  },
];

const archived = [
  {
    slug: 'pdd-holdings-v4',
    title: 'PDD Holdings: The Cash Machine Behind the Tariff Storm',
    date: 'March 20, 2026',
    version: 'V4',
    tag: 'E-Commerce · China · Deep Research',
  },
  {
    slug: 'china-ecommerce-industry-v3',
    title: 'Chinese E-Commerce: PDD Earnings Preview — $59.5B in Cash and the Buyback Question',
    date: 'March 23, 2026',
    version: 'V3',
    tag: 'E-Commerce · China · Earnings Preview',
  },
  {
    slug: 'china-ecommerce-industry-v2',
    title: 'Chinese E-Commerce: The Traffic Tax, the Subsidy Trap, and the Regulatory Reset',
    date: 'March 23, 2026',
    version: 'V2',
    tag: 'E-Commerce · China · Industry Analysis',
  },
  {
    slug: 'china-ecommerce-industry-v1',
    title: 'Chinese E-Commerce: Three Wars and a Reckoning',
    date: 'March 22, 2026',
    version: 'V1',
    tag: 'E-Commerce · China · Industry Analysis',
  },
  {
    slug: 'pdd-holdings-v3',
    title: 'PDD Holdings: The Metamorphosis',
    date: 'March 19, 2026',
    version: 'V3',
    tag: 'E-Commerce · China · Deep Research',
  },
  {
    slug: 'pdd-holdings-v2',
    title: 'PDD Holdings: From Summary to Prediction',
    date: 'March 18, 2026',
    version: 'V2',
    tag: 'E-Commerce · China · Predictions',
  },
  {
    slug: 'pdd-holdings',
    title: 'PDD Holdings: Two Companies, One Price',
    date: 'March 18, 2026',
    version: 'V1',
    tag: 'E-Commerce · China · Deep Dive',
  },
];
---

<Base title="E-commerce Analysis">
  <header class="site-header">
    <div class="masthead">
      <h1 class="site-title">E-commerce Analysis</h1>
      <p class="site-tagline">Institutional-quality e-commerce research. Open source. Evidence-backed.</p>
    </div>
    <nav class="site-nav">
      <span class="nav-section active">Latest</span>
      <span class="nav-section">Companies</span>
      <span class="nav-section">About</span>
    </nav>
  </header>

  <section class="featured">
    {reports.map((r) => (
      <a href={`${import.meta.env.BASE_URL}reports/${r.slug}/`} class="report-card featured-card">
        <div class="card-tag">{r.tag}</div>
        <h2 class="card-title">{r.title}</h2>
        <p class="card-subtitle">{r.subtitle}</p>
        <div class="card-meta">
          <span class="card-authors">{r.authors}</span>
          <span class="card-sep">·</span>
          <span class="card-date">{r.date}</span>
          <span class="card-sep">·</span>
          <span class="card-version">{r.version}</span>
          <span class="card-sep">·</span>
          <span class="card-read-time">{r.readTime}</span>
        </div>
      </a>
    ))}
  </section>

  <section class="coming-soon">
    <h3>Coming Soon</h3>
    <div class="upcoming-list">
      <div class="upcoming-item">
        <span class="upcoming-tag">E-Commerce · SE Asia</span>
        <span class="upcoming-title">Shopee vs Lazada: The Southeast Asian Battlefield</span>
      </div>
      <div class="upcoming-item">
        <span class="upcoming-tag">E-Commerce · Global</span>
        <span class="upcoming-title">Shein: The $30B Question</span>
      </div>
      <div class="upcoming-item">
        <span class="upcoming-tag">E-Commerce · US</span>
        <span class="upcoming-title">Amazon Haul: Too Little, Too Late?</span>
      </div>
    </div>
  </section>

  <section class="archive">
    <h3>Archive</h3>
    <div class="upcoming-list">
      {archived.map((r) => (
        <a href={`${import.meta.env.BASE_URL}reports/${r.slug}/`} class="upcoming-item archive-link">
          <span class="upcoming-tag">{r.tag}</span>
          <span class="upcoming-title">{r.title} <span class="archive-version">{r.version}</span></span>
        </a>
      ))}
    </div>
  </section>
</Base>

<style>
  .site-header {
    margin-bottom: 3rem;
  }

  .masthead {
    padding-bottom: 1.5rem;
    border-bottom: 3px solid #1a1a1a;
    margin-bottom: 1rem;
  }

  .site-title {
    font-size: 2.8rem;
    letter-spacing: -0.02em;
    margin-bottom: 0.25rem;
    border-bottom: none;
    padding-bottom: 0;
    margin-top: 0;
  }

  .site-tagline {
    color: #6b7280;
    font-size: 1rem;
    font-style: italic;
  }

  .site-nav {
    display: flex;
    gap: 1.5rem;
    padding: 0.75rem 0;
    border-bottom: 1px solid #e5e5e5;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    font-size: 0.9rem;
  }

  .nav-section {
    color: #6b7280;
    cursor: pointer;
  }

  .nav-section.active {
    color: #1a1a1a;
    font-weight: 600;
  }

  .featured {
    margin: 2rem 0;
  }

  .report-card {
    display: block;
    padding: 2rem 0;
    border-bottom: 1px solid #e5e5e5;
    text-decoration: none;
    color: inherit;
    transition: background 0.15s;
  }

  .report-card:hover {
    text-decoration: none;
  }

  .report-card:hover .card-title {
    color: #2563eb;
  }

  .card-tag {
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #2563eb;
    font-weight: 600;
    margin-bottom: 0.5rem;
  }

  .card-title {
    font-size: 1.8rem;
    line-height: 1.2;
    margin-bottom: 0.5rem;
    transition: color 0.15s;
  }

  .card-subtitle {
    font-size: 1.1rem;
    color: #4b5563;
    line-height: 1.5;
    margin-bottom: 0.75rem;
  }

  .card-meta {
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    font-size: 0.85rem;
    color: #9ca3af;
  }

  .card-sep {
    margin: 0 0.3rem;
  }

  .card-version {
    background: #f3f4f6;
    padding: 0.1rem 0.4rem;
    border-radius: 3px;
    font-weight: 600;
    font-size: 0.75rem;
  }

  .coming-soon {
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid #e5e5e5;
  }

  .coming-soon h3 {
    font-size: 1rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #9ca3af;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    margin-bottom: 1rem;
    margin-top: 0;
  }

  .upcoming-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .upcoming-item {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    padding: 0.75rem 0;
    border-bottom: 1px solid #f3f4f6;
  }

  .upcoming-tag {
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #9ca3af;
  }

  .upcoming-title {
    font-size: 1.1rem;
    color: #6b7280;
    font-style: italic;
  }

  .archive {
    margin-top: 2rem;
    padding-top: 2rem;
    border-top: 1px solid #e5e5e5;
  }

  .archive h3 {
    font-size: 1rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #9ca3af;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    margin-bottom: 1rem;
    margin-top: 0;
  }

  .archive-link {
    text-decoration: none;
    color: inherit;
  }

  .archive-link:hover .upcoming-title {
    color: #2563eb;
  }

  .archive-version {
    background: #f3f4f6;
    padding: 0.1rem 0.4rem;
    border-radius: 3px;
    font-weight: 600;
    font-size: 0.7rem;
    font-style: normal;
    color: #9ca3af;
  }
</style>
