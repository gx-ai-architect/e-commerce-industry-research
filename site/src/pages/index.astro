---
import Base from '../layouts/Base.astro';

const reports = [
  {
    slug: 'pdd-holdings-v4',
    title: 'PDD Holdings: The Cash Machine Behind the Tariff Storm',
    subtitle: 'Primary-source research: SEC EDGAR XBRL, CPSC API, Meta Ad Library, iTunes API, Trustpilot scraper, Tranco rankings. 59 evidence packets from 8 domain agents. 67 curated evidence entries, 297 auto-collected. 4 mosaic insights, 5 falsifiable predictions.',
    authors: 'GX Xu & Claude Code',
    date: 'March 20, 2026',
    version: 'V4',
    tag: 'E-Commerce · China · Deep Research',
    readTime: '28 min read',
  },
];

const archived = [
  {
    slug: 'pdd-holdings-v3',
    title: 'PDD Holdings: The Metamorphosis',
    date: 'March 19, 2026',
    version: 'V3',
    tag: 'E-Commerce · China · Deep Research',
  },
  {
    slug: 'pdd-holdings-v2',
    title: 'PDD Holdings: From Summary to Prediction',
    date: 'March 18, 2026',
    version: 'V2',
    tag: 'E-Commerce · China · Predictions',
  },
  {
    slug: 'pdd-holdings',
    title: 'PDD Holdings: Two Companies, One Price',
    date: 'March 18, 2026',
    version: 'V1',
    tag: 'E-Commerce · China · Deep Dive',
  },
];
---

<Base title="E-commerce Analysis">
  <header class="site-header">
    <div class="masthead">
      <h1 class="site-title">E-commerce Analysis</h1>
      <p class="site-tagline">Institutional-quality e-commerce research. Open source. Evidence-backed.</p>
    </div>
    <nav class="site-nav">
      <span class="nav-section active">Latest</span>
      <span class="nav-section">Companies</span>
      <span class="nav-section">About</span>
    </nav>
  </header>

  <section class="featured">
    {reports.map((r) => (
      <a href={`${import.meta.env.BASE_URL}reports/${r.slug}/`} class="report-card featured-card">
        <div class="card-tag">{r.tag}</div>
        <h2 class="card-title">{r.title}</h2>
        <p class="card-subtitle">{r.subtitle}</p>
        <div class="card-meta">
          <span class="card-authors">{r.authors}</span>
          <span class="card-sep">·</span>
          <span class="card-date">{r.date}</span>
          <span class="card-sep">·</span>
          <span class="card-version">{r.version}</span>
          <span class="card-sep">·</span>
          <span class="card-read-time">{r.readTime}</span>
        </div>
      </a>
    ))}
  </section>

  <section class="coming-soon">
    <h3>Coming Soon</h3>
    <div class="upcoming-list">
      <div class="upcoming-item">
        <span class="upcoming-tag">E-Commerce · SE Asia</span>
        <span class="upcoming-title">Shopee vs Lazada: The Southeast Asian Battlefield</span>
      </div>
      <div class="upcoming-item">
        <span class="upcoming-tag">E-Commerce · Global</span>
        <span class="upcoming-title">Shein: The $30B Question</span>
      </div>
      <div class="upcoming-item">
        <span class="upcoming-tag">E-Commerce · US</span>
        <span class="upcoming-title">Amazon Haul: Too Little, Too Late?</span>
      </div>
    </div>
  </section>

  <section class="archive">
    <h3>Archive</h3>
    <div class="upcoming-list">
      {archived.map((r) => (
        <a href={`${import.meta.env.BASE_URL}reports/${r.slug}/`} class="upcoming-item archive-link">
          <span class="upcoming-tag">{r.tag}</span>
          <span class="upcoming-title">{r.title} <span class="archive-version">{r.version}</span></span>
        </a>
      ))}
    </div>
  </section>
</Base>

<style>
  .site-header {
    margin-bottom: 3rem;
  }

  .masthead {
    padding-bottom: 1.5rem;
    border-bottom: 3px solid #1a1a1a;
    margin-bottom: 1rem;
  }

  .site-title {
    font-size: 2.8rem;
    letter-spacing: -0.02em;
    margin-bottom: 0.25rem;
    border-bottom: none;
    padding-bottom: 0;
    margin-top: 0;
  }

  .site-tagline {
    color: #6b7280;
    font-size: 1rem;
    font-style: italic;
  }

  .site-nav {
    display: flex;
    gap: 1.5rem;
    padding: 0.75rem 0;
    border-bottom: 1px solid #e5e5e5;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    font-size: 0.9rem;
  }

  .nav-section {
    color: #6b7280;
    cursor: pointer;
  }

  .nav-section.active {
    color: #1a1a1a;
    font-weight: 600;
  }

  .featured {
    margin: 2rem 0;
  }

  .report-card {
    display: block;
    padding: 2rem 0;
    border-bottom: 1px solid #e5e5e5;
    text-decoration: none;
    color: inherit;
    transition: background 0.15s;
  }

  .report-card:hover {
    text-decoration: none;
  }

  .report-card:hover .card-title {
    color: #2563eb;
  }

  .card-tag {
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #2563eb;
    font-weight: 600;
    margin-bottom: 0.5rem;
  }

  .card-title {
    font-size: 1.8rem;
    line-height: 1.2;
    margin-bottom: 0.5rem;
    transition: color 0.15s;
  }

  .card-subtitle {
    font-size: 1.1rem;
    color: #4b5563;
    line-height: 1.5;
    margin-bottom: 0.75rem;
  }

  .card-meta {
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    font-size: 0.85rem;
    color: #9ca3af;
  }

  .card-sep {
    margin: 0 0.3rem;
  }

  .card-version {
    background: #f3f4f6;
    padding: 0.1rem 0.4rem;
    border-radius: 3px;
    font-weight: 600;
    font-size: 0.75rem;
  }

  .coming-soon {
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid #e5e5e5;
  }

  .coming-soon h3 {
    font-size: 1rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #9ca3af;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    margin-bottom: 1rem;
    margin-top: 0;
  }

  .upcoming-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .upcoming-item {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    padding: 0.75rem 0;
    border-bottom: 1px solid #f3f4f6;
  }

  .upcoming-tag {
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #9ca3af;
  }

  .upcoming-title {
    font-size: 1.1rem;
    color: #6b7280;
    font-style: italic;
  }

  .archive {
    margin-top: 2rem;
    padding-top: 2rem;
    border-top: 1px solid #e5e5e5;
  }

  .archive h3 {
    font-size: 1rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #9ca3af;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    margin-bottom: 1rem;
    margin-top: 0;
  }

  .archive-link {
    text-decoration: none;
    color: inherit;
  }

  .archive-link:hover .upcoming-title {
    color: #2563eb;
  }

  .archive-version {
    background: #f3f4f6;
    padding: 0.1rem 0.4rem;
    border-radius: 3px;
    font-weight: 600;
    font-size: 0.7rem;
    font-style: normal;
    color: #9ca3af;
  }
</style>
